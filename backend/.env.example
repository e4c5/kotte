# ────────────────────────────────────────────────────────────────────────────
# Kotte backend — example environment file
#
# Copy this file to backend/.env and edit as needed:
#
#   cp backend/.env.example backend/.env
#
# Defaults below are tuned for **local development** against a Postgres+AGE
# instance running on localhost:5432. They will boot the backend without
# further edits; in particular SESSION_SECRET_KEY is auto-generated when
# ENVIRONMENT != "production".
#
# Lines marked  **REQUIRED IN PRODUCTION**  must be set to a real value
# before deploying with ENVIRONMENT=production, or the app will refuse to
# start (or refuse to use credential storage).
#
# Full reference: docs/CONFIGURATION.md
# Source of truth: backend/app/core/config.py (class Settings)
# ────────────────────────────────────────────────────────────────────────────

# ── Environment ────────────────────────────────────────────────────────────
# "development" | "production" | "test"
ENVIRONMENT=development
DEBUG=false

# ── Session security ───────────────────────────────────────────────────────
# **REQUIRED IN PRODUCTION.** Generate with:  openssl rand -base64 32
# In dev/test this can be left blank — Settings will auto-generate one and
# log a UserWarning. Do NOT rely on the auto-generated key in production.
SESSION_SECRET_KEY=

SESSION_COOKIE_NAME=kotte_session
SESSION_MAX_AGE=3600          # seconds  (1 hour absolute lifetime)
SESSION_IDLE_TIMEOUT=1800     # seconds  (30 min idle timeout)

# ── Default admin account ──────────────────────────────────────────────────
# **REQUIRED IN PRODUCTION.** Defaults to "admin" in dev, which the backend
# refuses to accept when ENVIRONMENT=production. Generate with:
#   openssl rand -base64 24
# The plaintext is bcrypt-hashed on first use; not persisted at rest.
ADMIN_PASSWORD=admin

# ── Database (server-side defaults) ────────────────────────────────────────
# These are used for server-side operations only; end users connect through
# the UI with their own credentials. Override DB_HOST=age when running via
# the Docker Compose stack in deployment/.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Per-session connection pool tuning. Multiplied across active sessions, so
# the worst-case PostgreSQL connection load is roughly  (DB_POOL_MAX_SIZE × N).
DB_CONNECT_TIMEOUT=10         # seconds to establish a TCP+auth connection
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_IDLE=300          # seconds before an idle pooled conn is closed

# ── CORS ───────────────────────────────────────────────────────────────────
# Allowed origins for the frontend. Pydantic-Settings parses List[str]
# from env vars as JSON, so this MUST be a JSON array (not comma-separated)
# even though docs/CONFIGURATION.md currently shows the comma form. There
# is a tracked follow-up to add a validator that accepts both shapes.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Query limits ───────────────────────────────────────────────────────────
QUERY_TIMEOUT=300             # seconds; wall-clock timeout for a single query
QUERY_MAX_RESULT_ROWS=100000  # caps streamed result rows to protect memory
QUERY_MAX_VARIABLE_HOPS=20    # max `*1..N` hops accepted in Cypher validator
QUERY_SAFE_MODE=false         # true → reject mutating queries (read-only mode)

# ── Visualisation limits ───────────────────────────────────────────────────
# Soft caps the frontend uses to refuse to render impossibly-large graphs.
MAX_NODES_FOR_GRAPH=5000
MAX_EDGES_FOR_GRAPH=10000

# ── CSV import limits ──────────────────────────────────────────────────────
IMPORT_MAX_FILE_SIZE=104857600    # bytes  (100 MiB)
IMPORT_MAX_ROWS=1000000
MAX_IMPORT_JOBS=1000              # in-memory job table cap; oldest evicted
IMPORT_JOB_TTL_SECONDS=86400      # remove import jobs older than 24h

# ── Logging ────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# true → JSON log lines (recommended for production); false → human-readable
STRUCTURED_LOGGING=true

# ── Credential storage (saved DB connections) ──────────────────────────────
# How encrypted saved-connection blobs are stored.
# Supported: json_file | sqlite | postgresql | redis
CREDENTIAL_STORAGE_TYPE=json_file
CREDENTIAL_STORAGE_PATH=./data/connections.json

# **REQUIRED IN PRODUCTION** when credential storage is used.
# Generate with:  openssl rand -base64 32
# Dev: if blank, a key is auto-generated on first use and persisted next to
# the connections file as `.master_encryption_key`. Rotating this key
# *invalidates* all previously-encrypted saved connections — see
# docs/CONFIGURATION.md "Key Rotation" before changing it.
MASTER_ENCRYPTION_KEY=

# ── Redis (Milestone D: multi-user sessions and query tracking) ───────────
# Optional. Set REDIS_ENABLED=true to use Redis for SessionManager and
# QueryTracker (required for multi-user deployments). When false (default),
# uses in-memory stores. Graceful fallback allows single-instance dev setups
# to skip Redis entirely.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Security middleware ────────────────────────────────────────────────────
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60      # per IP, sliding 60-second window
RATE_LIMIT_PER_USER=100       # per authenticated user, sliding 60-second window
