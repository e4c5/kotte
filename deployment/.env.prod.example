# Kotte production deployment — environment example (ROADMAP B6)
#
# Copy this file to `.env.prod` in the same folder and fill in real values,
# then run:
#
#   docker compose -f deployment/docker-compose.prod.yml --env-file \
#     deployment/.env.prod up -d
#
# The committed file is .env.prod.example (this one). .env.prod is in
# .gitignore — never commit a populated production env file.
#
# See backend/.env.example for the exhaustive list of every backend
# configuration key. The list below is the minimum subset needed for a
# working production compose stack; additional tuning (rate limits,
# cache TTLs, pool sizing, etc.) can be layered in by copying keys from
# the backend example.

# --- REQUIRED ---------------------------------------------------------------

# Postgres password for the `postgres` user inside the age container. Must
# match what the backend uses to connect; compose wires both sides off this
# variable.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Mirror for the backend; kept explicit so a future compose refactor can
# separate the db-admin credential from the app credential without a
# schema change.
DB_PASSWORD=change-me-to-a-long-random-string

# 32+ bytes of randomness. Used to sign session cookies. Rotating this
# invalidates every logged-in session. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=change-me-to-a-32-byte-random-value

# Origin(s) the backend will accept CORS requests from. pydantic-settings
# parses `List[str]` fields as JSON, so the value must be a JSON array —
# even for a single origin (see CONFIGURATION.md for the gotcha).
CORS_ORIGINS=["https://kotte.example.com"]

# --- RECOMMENDED ------------------------------------------------------------

# Admin password used to bootstrap the first user via the admin CLI. Remove
# once the admin account is provisioned.
# ADMIN_PASSWORD=change-me

# Encryption key for the credential store (AES-256-GCM). Rotating this
# re-encrypts saved connections on next write. Generate the same way as
# SESSION_SECRET_KEY.
# CREDENTIAL_ENCRYPTION_KEY=change-me

# --- OPTIONAL TUNING --------------------------------------------------------

# Log level. INFO is sane for production; DEBUG is noisy.
# LOG_LEVEL=INFO

# Rate-limit toggles. Leave at defaults unless you're seeing abuse.
# RATE_LIMIT_ENABLED=true

# CSRF gate. MUST stay on in production. Only set to false for a quick
# local reproduction, then delete this line from the file.
# CSRF_ENABLED=true
